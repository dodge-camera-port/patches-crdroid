 configs/display/displayconfig.xml | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/configs/display/displayconfig.xml b/configs/display/displayconfig.xml
index 45d6909..82e7d03 100644
--- a/configs/display/displayconfig.xml
+++ b/configs/display/displayconfig.xml
@@ -147,6 +147,16 @@
         <timeMaxSecs>300</timeMaxSecs>         // Maximum time of HBM allowed in that window.
         <timeMinSecs>60</timeMinSecs>          // Minimum time remaining required to switch
         </timing>                              //   HBM on for.
