+                <sdrNits>2.000</sdrNits>
+                <hdrRatio>8.000</hdrRatio>
+            </point>
+            <point>
+                <sdrNits>500.000</sdrNits>
+                <hdrRatio>1.5</hdrRatio>
+            </point>
+        </sdrHdrRatioMap>
     </highBrightnessMode>
 
     <screenBrightnessRampFastDecrease>0.5</screenBrightnessRampFastDecrease>
