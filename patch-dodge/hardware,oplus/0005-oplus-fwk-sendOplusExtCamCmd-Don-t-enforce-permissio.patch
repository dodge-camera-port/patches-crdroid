From e2844aff4077d2bd5462ee6548dd6713abb22764 Mon Sep 17 00:00:00 2001
From: Hecheng Yu <kde-yyds@qq.com>
Date: Sun, 31 May 2026 19:10:32 +0800
Subject: [PATCH 5/7] oplus-fwk: sendOplusExtCamCmd: Don't enforce permissiom
 PERMISSION_SAFE_CAMERA

Oplus camera on OnePlus 13 set zoom level by sending CMD_UI_EVENT. But this permission is not available on AOSP custom ROM.
---
 oplus-fwk/src/android/hardware/camera2/OplusCameraManager.java | 1 -
 1 file changed, 1 deletion(-)

diff --git a/oplus-fwk/src/android/hardware/camera2/OplusCameraManager.java b/oplus-fwk/src/android/hardware/camera2/OplusCameraManager.java
index 580ba96..ca182cb 100644
--- a/oplus-fwk/src/android/hardware/camera2/OplusCameraManager.java
+++ b/oplus-fwk/src/android/hardware/camera2/OplusCameraManager.java
@@ -184,7 +184,6 @@ public final class OplusCameraManager implements IOplusCameraManager {
         if (context == null) {
             throw new IllegalArgumentException("context was null");
         }
-        context.enforceCallingOrSelfPermission(PERMISSION_SAFE_CAMERA, TAG);
         try {
             OplusCameraManagerGlobal.get().sendOplusExtCamCmd(context.getOpPackageName(), cmd, param);
         } catch (CameraAccessException e) {
