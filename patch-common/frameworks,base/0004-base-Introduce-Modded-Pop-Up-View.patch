+        private void addHandleToRegion(Region region, View handle) {
+            if (handle.getVisibility() == VISIBLE) {
+                region.op(handle.getLeft(), handle.getTop(),
+                        handle.getRight(), handle.getBottom(),
+                        Region.Op.UNION);
+            }
+        }
