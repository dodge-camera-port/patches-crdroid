diff --git a/services/core/java/com/android/server/wm/DimmerWindow.java b/services/core/java/com/android/server/wm/DimmerWindow.java
new file mode 100644
index 000000000..856022783
--- /dev/null
+++ b/services/core/java/com/android/server/wm/DimmerWindow.java
@@ -0,0 +1,428 @@
+/*
+ * Copyright (C) 2023-2024 The Nameless-AOSP Project
