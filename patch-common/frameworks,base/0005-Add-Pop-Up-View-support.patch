+        if (!isPinned) {
+            mWindowSurfaceScaleFactor = WindowResizingAlgorithm.getPositionAndScaleFactorForTask(
+                    bound, displayBound, mWindowCenterPosition, mWindowSurfaceScale,
+                    false, pos);
