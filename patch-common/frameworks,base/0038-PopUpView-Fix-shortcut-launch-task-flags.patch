From 41767ddbcdc012387595ccc4bb0cb3fda1ef5b3f Mon Sep 17 00:00:00 2001
From: uwu-gl <moegluwu0@gmail.com>
Date: Tue, 9 Jun 2026 22:42:40 +0800
Subject: [PATCH 38/43] PopUpView: Fix shortcut launch task flags

---
 .../systemui/statusbar/phone/popup/PopUpQuickMenuController.kt   | 1 +
 services/core/java/com/android/server/wm/PopUpAppStarter.java    | 1 +
 2 files changed, 2 insertions(+)

diff --git a/packages/SystemUI/src/com/android/systemui/statusbar/phone/popup/PopUpQuickMenuController.kt b/packages/SystemUI/src/com/android/systemui/statusbar/phone/popup/PopUpQuickMenuController.kt
index a15f291ef..30bf44c9c 100644
--- a/packages/SystemUI/src/com/android/systemui/statusbar/phone/popup/PopUpQuickMenuController.kt
+++ b/packages/SystemUI/src/com/android/systemui/statusbar/phone/popup/PopUpQuickMenuController.kt
@@ -188,6 +188,7 @@ constructor(
     private fun launchShortcut(target: QuickMenuTarget.Shortcut) {
         val options = ActivityOptions.makeBasic().apply {
             setLaunchWindowingMode(WindowConfiguration.WINDOWING_MODE_MINI_WINDOW_EXT)
+            setApplyMultipleTaskFlagForShortcut(true)
             setPendingIntentBackgroundActivityStartMode(
                 ActivityOptions.MODE_BACKGROUND_ACTIVITY_START_ALLOWED
             )
diff --git a/services/core/java/com/android/server/wm/PopUpAppStarter.java b/services/core/java/com/android/server/wm/PopUpAppStarter.java
index ead938e07..b0d36502e 100644
--- a/services/core/java/com/android/server/wm/PopUpAppStarter.java
+++ b/services/core/java/com/android/server/wm/PopUpAppStarter.java
@@ -90,6 +90,7 @@ class PopUpAppStarter {
     static Bundle getMiniWindowBundle() {
         ActivityOptions options = ActivityOptions.makeBasic();
         options.setLaunchWindowingMode(WINDOWING_MODE_MINI_WINDOW_EXT);
+        options.setApplyMultipleTaskFlagForShortcut(true);
         options.setPendingIntentBackgroundActivityStartMode(MODE_BACKGROUND_ACTIVITY_START_ALLOWED);
         return options.toBundle();
     }
-- 
