                 case MotionEvent.ACTION_MOVE:
+                    ensureMiniVelocityTracker().addMovement(event);
                     final int moveX = (int) event.getRawX();
                     final int moveY = (int) event.getRawY();
                     if (!mLegacyDragging) {
