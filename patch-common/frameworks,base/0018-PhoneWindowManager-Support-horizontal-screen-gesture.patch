From 097a58b408fde45db91108020b61736753826ddf Mon Sep 17 00:00:00 2001
From: ruyue <ruyueee@outlook.com>
Date: Thu, 6 Nov 2025 16:26:45 +0800
Subject: [PATCH 18/43] PhoneWindowManager: Support horizontal screen gestures

Change-Id: Ibf1ba1bb2c21f9339810c2197dab6b195fd1d3d4
---
 .../server/policy/PhoneWindowManager.java     | 32 +++++++++++++++++++
 1 file changed, 32 insertions(+)

diff --git a/services/core/java/com/android/server/policy/PhoneWindowManager.java b/services/core/java/com/android/server/policy/PhoneWindowManager.java
index 43e5ad7e4..82c0857af 100644
--- a/services/core/java/com/android/server/policy/PhoneWindowManager.java
+++ b/services/core/java/com/android/server/policy/PhoneWindowManager.java
@@ -7193,6 +7193,38 @@ public class PhoneWindowManager implements WindowManagerPolicy {
         }
     }
 
+    private final DisplayManager.DisplayListener mDisplayListener =
+        new DisplayManager.DisplayListener() {
+        @Override
+        public void onDisplayAdded(int displayId) {}
+
+        @Override
+        public void onDisplayRemoved(int displayId) {}
+
+        @Override
+        public void onDisplayChanged(int displayId) {
+            if (displayId == Display.DEFAULT_DISPLAY) {
+                updateGestureParams();
+                mIsTrackingSideGesture = false;
+                mGestureTriggered = false;
+            }
+        }
+    };
+
+    private void updateGestureParams() {
+        Display display = mDisplayManager.getDisplay(Display.DEFAULT_DISPLAY);
+        if (display != null) {
+            Point size = new Point();
+            display.getRealSize(size);
+            mDisplayWidth = size.x;
+            mDisplayHeight = size.y;
+        }
+        float density = mContext.getResources().getDisplayMetrics().density;
+        mMinGestureDistancePx = TRIGGER_MIN_DISTANCE_DP * density;
+        mGestureAreaHeightPx  = GESTURE_AREA_HEIGHT_DP  * density;
+        mGestureAreaWidthPx   = GESTURE_AREA_WIDTH_DP   * density;
+    }
+
 
 
     /** {@inheritDoc} */
