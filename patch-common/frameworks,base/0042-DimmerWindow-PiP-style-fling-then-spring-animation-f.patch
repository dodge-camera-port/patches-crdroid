+        // Phase 2: spring settle after fling hits edge (PiP flingThenSpring equivalent)
+        private void startMiniWindowEdgeSpring(float startX, float startY,
+                float velX, float velY, int targetX, int targetY) {
+            // PiP: STIFFNESS=700, DAMPING_RATIO_NO_BOUNCY=1.0
+            // Overshoot comes from fling momentum, not spring bounce
+            final float kx = 300f;
+            final float cx = 34.6f;     // ζ=1.0 — no bounce, smooth settle
+            final float ky = 120f;
+            final float cy = 17.0f;     // ζ=0.78 — tiny hint of bounce on Y
+            final float dt = 0.016f;
+            ValueAnimator springAnim = ValueAnimator.ofFloat(0f, 1f);
+            springAnim.setDuration(800);
+            final float[] posX = {startX};
+            final float[] vx = {velX};
+            final float[] posY = {startY};
+            final float[] vy = {velY};
+            springAnim.addUpdateListener(anim -> {
+                float fx = -kx * (posX[0] - targetX) - cx * vx[0];
+                vx[0] += fx * dt;
+                posX[0] += vx[0] * dt;
+                float fy = -ky * (posY[0] - targetY) - cy * vy[0];
+                vy[0] += fy * dt;
+                posY[0] += vy[0] * dt;
+                final Rect newBounds = new Rect(mDrawingRect);
+                newBounds.offsetTo(Math.round(posX[0]), Math.round(posY[0]));
+                updateLayout(newBounds);
+                moveTaskSurface(newBounds.centerX(), newBounds.centerY());
+                // Let bounces play out — only stop when truly settled
+                float totalEnergy = vx[0] * vx[0] + vy[0] * vy[0]
+                        + kx * (posX[0] - targetX) * (posX[0] - targetX)
+                        + ky * (posY[0] - targetY) * (posY[0] - targetY);
+                if (totalEnergy < 100) {
+                    anim.cancel();
+                }
+            });
+            springAnim.addListener(new android.animation.AnimatorListenerAdapter() {
+                @Override
+                public void onAnimationEnd(android.animation.Animator animation) {
+                    mMiniWindowSpringAnim = null;
+                    final Rect finalBounds = new Rect(mDrawingRect);
+                    finalBounds.offsetTo(targetX, targetY);
+                    updateLayout(finalBounds);
+                    moveTaskSurface(finalBounds.centerX(), finalBounds.centerY());
+                }
+            });
+            springAnim.start();
+            mMiniWindowSpringAnim = springAnim;
         }
 
